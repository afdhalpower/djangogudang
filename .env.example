# Django core
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database switch:
#   - Leave DB_ENGINE empty  -> SQLite (default, zero setup, great for learning)
#   - Set DB_ENGINE=postgres -> PostgreSQL (production target)
# Switching is ONE variable, exactly like changing the DB driver in
# Laravel's config/database.php. No code changes needed.
DB_ENGINE=
DB_NAME=warehouse
DB_USER=warehouse
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
